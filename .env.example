# AI provider API key (required outside local fallback mode)
# Groq is used by the current backend implementation.
GROQ_API_KEY=your-groq-api-key-here

# Optional compatibility variable for older Gemini deployments.
GEMINI_API_KEY=

# Application Secret Key (change in production)
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database (defaults work with docker-compose)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_interviewer
# DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_interviewer

# CORS_ORIGINS='["http://localhost:3000"]'
# MAX_RESUME_UPLOAD_BYTES=5242880
