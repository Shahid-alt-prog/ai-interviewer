# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_interviewer
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/ai_interviewer

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Text-to-Speech
SARVAM_API_KEY=your-sarvam-api-key-here
